@model List<CheckersWeb.Models.Game>
@{
    ViewData["Title"] = "Game History";
    var username = User.Identity?.Name;
}
<div style="max-width: 700px; margin: 2rem auto;">
    <h2>📜 Game History</h2>
    @if (!Model.Any())
    {
        <p class="text-muted">You haven't played any games yet.</p>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Game #</th>
                    <th>Opponent</th>
                    <th>Moves</th>
                    <th>Started</th>
                    <th>Result</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model)
                {
                    var opponent = game.Player1?.Username == username
                    ? game.Player2?.Username ?? "Waiting..."
                    : game.Player1?.Username ?? "Unknown";
                    var result = "In Progress";
                    if (game.WinnerId != null)
                        result = game.Winner?.Username == username ? "Win" : "Loss";
                    <tr>
                        <td>#@game.Id</td>
                        <td>@opponent</td>
                        <td>@game.Moves.Count</td>
                        <td>@game.StartedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (result == "Win")
                            {
                                <span class="badge bg-success">Win</span>
                            }
                            else if (result == "Loss")
                            {
                                <span class="badge bg-danger">Loss</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">In Progress</span>
                            }
                        </td>
                        <td>
                            @if (game.WinnerId == null)
                            {
                                <a href="/Game/Index?gameId=@game.Id" class="btn btn-sm btn-primary">Resume</a>
                            }
                            else
                            {
                                <a href="/Game/Details?gameId=@game.Id" class="btn btn-sm btn-outline-secondary">🔍 View Moves</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">← Back to Home</a>
</div>