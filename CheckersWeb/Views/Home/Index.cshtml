@model List<CheckersWeb.Models.Game>
@{
    ViewData["Title"] = "Home Page";
}
<div class="text-center">
    <h1 class="display-4">Welcome To Our Project</h1>
    @if (User.Identity!.IsAuthenticated)
    {
        <h3>Welcome @User.Identity.Name 👋</h3>
    }
    else
    {
        <h3>Please Login or Create User</h3>
    }

</div>

@if (User.Identity!.IsAuthenticated)
{
    var myGames = ViewBag.MyGames as IEnumerable<dynamic>;
    if (myGames != null && myGames.Any())
    {
        <div class="mt-4" style="max-width:600px; margin: 1.5rem auto;">
            <h4>⚔️ Your Active Games</h4>
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Game #</th>
                        <th>Opponent</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in myGames)
                    {
                        <tr>
                            <td>#@g.Id</td>
                            <td>@g.Opponent</td>
                            <td>
                                @if (g.MyTurn)
                                {
                                    <span class="badge bg-success">Your turn</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Their turn</span>
                                }
                            </td>
                            <td>
                                <a href="/Game/Index?gameId=@g.Id" class="btn btn-sm btn-primary me-1">Resume</a>
                                <form method="post" asp-controller="Home" asp-action="QuitGame" style="display:inline;"
                                      onsubmit="return confirm('Are you sure you want to quit? You will lose this game.');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="gameId" value="@g.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Quit</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<div class="mt-5" style="max-width: 600px; margin: 2rem auto;">
    <h4>🎮 Open Games</h4>
    @if (Model == null || !Model.Any())
    {
        <p class="text-muted">No open games right now. Be the first to create one!</p>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Game #</th>
                    <th>Host</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model)
                {
                    <tr>
                        <td>#@game.Id</td>
                        <td>@(game.Player1?.Name ?? "Unknown")</td>
                        <td><span class="badge bg-warning text-dark">Waiting for opponent</span></td>
                        <td>
                            @if (User.Identity!.IsAuthenticated)
                            {
                                <a href="/Game/Join/@game.InviteCode" class="btn btn-sm btn-primary">Join</a>
                            }
                            else
                            {
                                <a asp-controller="Home" asp-action="Login" class="btn btn-sm btn-secondary">Login to Join</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="mt-4" style="max-width: 600px; margin: 2rem auto;">
    <h4>🏆 Leaderboard</h4>
    @{
        var leaderboard = ViewBag.Leaderboard as IEnumerable<dynamic>;
    }
    @if (leaderboard == null || !leaderboard.Any())
    {
        <p class="text-muted">No completed games yet.</p>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Player</th>
                    <th>Wins</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int rank = 1;
                }
                @foreach (var entry in leaderboard)
                {
                    <tr>
                        <td>@rank</td>
                        <td>@entry.Username</td>
                        <td>@entry.Wins</td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    }
</div>